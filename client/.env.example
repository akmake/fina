# ===== Fina client env =====
# העתק ל-.env ומלא ערכים אמיתיים.

# Base URL של ה-API — חובה, כל הקריאות נכשלות בלעדיו
VITE_API_URL=http://localhost:4000/api

# Google OAuth client ID (חייב להתאים ל-GOOGLE_CLIENT_ID בשרת)
VITE_GOOGLE_CLIENT_ID=

# Build
VITE_BUILD_TARGET=es2020

# Debug Mode
VITE_DEBUG=false
