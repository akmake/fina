# Authentication & Security
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_chars
CSRF_SECRET=your_csrf_secret_key_here

# Database
MONGO_URI=mongodb://mongo:27017/fina
DATABASE_URL=mongodb://localhost:27017/fina_local

# Server
PORT=4000
NODE_ENV=development

# Client URLs
CLIENT_URL=http://localhost:5173
DEPLOYMENT_URL=https://your-deployment-url.com

# External APIs (if needed)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key

# Session & Cookies
SESSION_SECRET=your_session_secret_key_here

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
