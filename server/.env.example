# Server Configuration
PORT=4000
NODE_ENV=development

# Database
MONGO_URI=mongodb://mongo:27017/pasover

# Security
JWT_ACCESS_SECRET=your-super-secret-access-key-change-it-now
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-it-now
JWT_ACCESS_EXPIRES_IN_SECONDS=900 # 15 minutes
JWT_REFRESH_EXPIRES_IN_SECONDS=604800 # 7 days

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173